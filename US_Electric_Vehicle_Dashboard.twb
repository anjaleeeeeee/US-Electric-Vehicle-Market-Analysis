      </column>
      <column caption='Total BEV Vehicles' datatype='integer' name='[Average_ER (copy)_1200913036607229953]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Electric Vehicle Type] = &quot;Battery Electric Vehicle (BEV)&quot; THEN [DOL Vehicle ID] END)' />
      </column>
      <column caption='CAFV_Count' datatype='integer' name='[Average_ER (copy)_1200913036610560003]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Clean Alternative Fuel Vehicle (CAFV) Eligibility] == &quot;Clean Alternative Fuel Vehicle Eligible&quot; THEN [DOL Vehicle ID] END)' />
      </column>
      <column caption='Not CAFV_Count' datatype='integer' name='[Average_ER (copy)_888123970525528064]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Clean Alternative Fuel Vehicle (CAFV) Eligibility] == &quot;Not eligible due to low battery range&quot; THEN [DOL Vehicle ID] END)' />
      </column>
      <column caption='PHEV %' datatype='real' name='[BEV % (copy)_970807245203828738]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Total BEV Vehicles (copy)_1200913036608229378]/[Calculation_1115907593517821952] * 100' />
      </column>
      <column caption='Unknown CAFV_Count ' datatype='integer' name='[CAFV_Count (copy)_888123970527436801]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Clean Alternative Fuel Vehicle (CAFV) Eligibility] == &quot;Eligibility unknown as battery range has not been researched&quot; THEN [DOL Vehicle ID] END)' />
      </column>
      <column caption='Total Vehicles' datatype='integer' name='[Calculation_1115907593517821952]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([DOL Vehicle ID])' />
      </column>
      <column caption='CAFV Eligibility Rate' datatype='real' name='[Calculation_1200913036610854916]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Average_ER (copy)_1200913036610560003]/[Calculation_1115907593517821952]*100' />
      </column>
      <column datatype='string' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
